# controlp.io — Environment Variables
#
# Copy this file to `.env.local` and fill in values.
# Never commit `.env.local` or any file containing real secrets.
# Add `.env*` to .gitignore except for `.env.example`.

# =====================================================
# APP
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=controlp.io
NEXT_PUBLIC_SUPPORT_PHONE=(480) 999-9906
NEXT_PUBLIC_SUPPORT_EMAIL=hello@controlp.io

NODE_ENV=development

# =====================================================
# SUPABASE (cloud project: kwyzxqlbwraiqftfjgjj)
# Dashboard: https://supabase.com/dashboard/project/kwyzxqlbwraiqftfjgjj
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://kwyzxqlbwraiqftfjgjj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_gD-BnrmZC7-42PlyP3UJiw_00znWlAC
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # from Supabase dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=            # from Supabase dashboard → Project Settings → API

# For running migrations via Supabase CLI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.kwyzxqlbwraiqftfjgjj.supabase.co:5432/postgres

# =====================================================
# AUTH (NextAuth v5)
# =====================================================
AUTH_SECRET=                          # generate: openssl rand -base64 32
AUTH_URL=http://localhost:3000        # production: https://controlp.io

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# =====================================================
# STRIPE
# =====================================================
STRIPE_SECRET_KEY=                    # sk_test_* for dev, sk_live_* for prod
STRIPE_PUBLISHABLE_KEY=               # pk_test_* for dev, pk_live_* for prod
STRIPE_WEBHOOK_SECRET=                # from `stripe listen` or dashboard

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # same as STRIPE_PUBLISHABLE_KEY (exposed to client)

# =====================================================
# TWILIO (SMS)
# =====================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+14809999906      # controlp.io business number
TWILIO_MESSAGING_SERVICE_SID=         # optional, for A2P 10DLC campaign

# =====================================================
# EMAIL
# =====================================================
# Transactional: Nodemailer via Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=hello@controlp.io
SMTP_PASSWORD=
SMTP_FROM=controlp.io <hello@controlp.io>

# Marketing: Resend
RESEND_API_KEY=
RESEND_FROM=controlp.io <newsletter@controlp.io>

# =====================================================
# VENDOR APIs
# =====================================================
# 4Over (reseller API — requires reseller account)
VENDOR_4OVER_API_URL=https://api-sandbox.4over.com   # prod: https://api.4over.com
VENDOR_4OVER_API_KEY=

# B2Sign (OAuth 2.0)
VENDOR_B2SIGN_API_URL=https://api.b2sign.com
VENDOR_B2SIGN_CLIENT_ID=
VENDOR_B2SIGN_CLIENT_SECRET=
VENDOR_B2SIGN_WEBHOOK_SECRET=         # HMAC secret for webhook verification

# =====================================================
# FILE STORAGE (Supabase Storage)
# =====================================================
# Bucket names (created via Supabase dashboard or migration)
SUPABASE_BUCKET_ARTWORK=artwork       # customer-uploaded artwork
SUPABASE_BUCKET_PROOFS=proofs         # admin-uploaded proofs
SUPABASE_BUCKET_TEMPLATES=templates   # design template library

# =====================================================
# ANALYTICS
# =====================================================
# PostHog (self-hosted or cloud)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =====================================================
# MONITORING
# =====================================================
# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                    # for source map uploads
NEXT_PUBLIC_SENTRY_DSN=

# =====================================================
# RATE LIMITING / CACHE (optional — v2)
# =====================================================
# Upstash Redis
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# =====================================================
# CRON
# =====================================================
# Secret for authenticating cron endpoints so they can't be hit externally
CRON_SECRET=                          # generate: openssl rand -hex 32
